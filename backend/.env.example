# Get from neon.tech (free) → New Project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Your dashboard login password
DASHBOARD_PASSWORD=your-secret-password

# From apify.com → Settings → Integrations → API token
APIFY_TOKEN=your-apify-api-token

# From aistudio.google.com → Get API key
GEMINI_API_KEY=your-gemini-api-key

# Your Vercel frontend URL (set after frontend deploys)
FRONTEND_URL=https://your-frontend.vercel.app

# Any random string — used to secure the cron endpoint
CRON_SECRET=any-random-secret-string

NODE_ENV=production
